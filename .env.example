# Linkyard environment variables
# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────

# Postgres password — used by the db container and embedded in connection URLs.
# Set to a random secret — generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# asyncpg URL — used by SQLAlchemy async engine at runtime
DATABASE_URL=postgresql+asyncpg://linkyard:${POSTGRES_PASSWORD}@localhost:5432/linkyard

# psycopg URL — used by Alembic for synchronous migrations
DATABASE_URL_SYNC=postgresql://linkyard:${POSTGRES_PASSWORD}@localhost:5432/linkyard

# ── Auth ──────────────────────────────────────────────────────────────────────

# Static bearer token for /settings endpoints.
# Leave unset or empty to disable auth (safe for local dev).
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# Reserved for future API key encryption — not yet active.
# Generate with: openssl rand -hex 32
SECRET_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────

# Regex matched against the Origin header for browser extension requests.
# In dev: any valid Chrome extension ID is accepted (32 a-p chars).
# In prod: pin to your published extension ID after publishing to Chrome Web Store.
# Example: chrome-extension://abcdefghijklmnopabcdefghijklmnop
CORS_ORIGIN_REGEX=chrome-extension://[a-p]{32}

# ── Embeddings ────────────────────────────────────────────────────────────────

# Provider: "local" (sentence-transformers, no API key needed) or "openai"
EMBEDDING_PROVIDER=local

# Must match the model's actual output dimension.
# local (multi-qa-MiniLM-L6-cos-v1) → 384
# openai (text-embedding-3-small)    → 1536
EMBEDDING_DIM=384

# ── Demo seed ─────────────────────────────────────────────────────────────────

# When true, the backend pre-loads ~40 example links on first boot if the
# database is empty. Idempotent — once links exist, the loader is a no-op.
# Used by the Fly.io live demo; safe to leave on for self-hosted demos.
DEMO_SEED=false
