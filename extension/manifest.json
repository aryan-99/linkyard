{
  "manifest_version": 3,
  "name": "Linkyard",
  "version": "1.0.0",
  "description": "Save the current page to Linkyard.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ],
  "optional_host_permissions": ["*://*/*"],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "src/icons/icon-16.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  },
  "action": {
    "default_title": "Save to Linkyard",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "48": "src/icons/icon-48.png",
      "128": "src/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  }
}
