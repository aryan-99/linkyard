{
  "manifest_version": 3,
  "name": "Linkyard",
  "version": "0.1.0",
  "description": "Save the current page to Linkyard.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": false
  },
  "action": {
    "default_title": "Save to Linkyard",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  }
}
