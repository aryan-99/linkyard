# Database (matches docker-compose.dev.yml defaults)
DATABASE_URL=postgresql+asyncpg://linkyard:linkyard@localhost:5432/linkyard
DATABASE_URL_SYNC=postgresql://linkyard:linkyard@localhost:5432/linkyard

# App
DEBUG=true

# Embedding provider: stub | local | openai
EMBEDDING_PROVIDER=stub
EMBEDDING_DIM=384

# OpenAI (only if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# CORS — comma separated
CORS_ORIGINS=http://localhost:5173,chrome-extension://
